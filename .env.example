# API Keys
POLYGON_API_KEY=your_polygon_api_key
FMP_API_KEY=your_fmp_api_key
ROIC_API_KEY=your_roic_api_key
XAI_API_KEY=your_xai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Agent settings
ALERT_PREFIX=grok-stock-alerts-agent
SCAN_INTERVAL_MINUTES=10
PREMARKET_START_MINUTES_BEFORE_OPEN=15
MIN_PRICE=2.0
MIN_VOLUME=100000
BREAKOUT_VOLUME_MULTIPLIER=2.0
BREAKOUT_PRICE_PCT=3.0
MAX_WATCHLIST_SIZE=50
MAX_DAILY_ALERTS=3
MIN_CONVICTION_SCORE=0.58
MIN_ALERT_CONFIDENCE=0.68
MIN_CONVICTION_PRICE=5.0
MAX_ANALYSIS_SYMBOLS=20
ENABLE_XAI_CATALYST_SEARCH=true
ENABLE_CLAUDE_VALIDATION=true
XAI_MODEL=grok-3-fast
CLAUDE_MODEL=claude-sonnet-4-20250514

# Market (US equities)
MARKET_TIMEZONE=America/New_York
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=30
MARKET_CLOSE_HOUR=16
MARKET_CLOSE_MINUTE=0